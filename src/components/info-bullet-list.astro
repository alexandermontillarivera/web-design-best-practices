---
interface Props {
  items: string[]
  tone?: "accent" | "bad"
}

const { items, tone = "accent" } = Astro.props
const dotClass = tone === "bad" ? "bg-bad" : "bg-accent"
---

<ul class="mt-4 space-y-3">
  {
    items.map((item) => (
      <li class="flex items-start gap-3 text-sm leading-relaxed text-foreground">
        <span class:list={["mt-[0.42rem] h-1.5 w-1.5 shrink-0 rounded-full", dotClass]} />
        <span class="flex-1">{item}</span>
      </li>
    ))
  }
</ul>
