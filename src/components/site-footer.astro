---
interface Props {
	text?: string
}

const {
	text = "Comparador interactivo de principios de ingeniería del diseño web",
} = Astro.props
---

<footer class="border-t border-border">
	<div class="mx-auto max-w-5xl px-5 py-10">
		<p class="font-mono text-xs text-muted">{text}</p>
	</div>
</footer>
