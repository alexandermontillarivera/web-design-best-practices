---
import "@/styles/global.css"

interface Props {
  title?: string
  description?: string
}

const {
  title = "Comparador de Diseño Web — Bien vs Mal implementado",
  description = "Herramienta interactiva estilo Squoosh para comparar implementaciones correctas e incorrectas de los principios de ingeniería del diseño web.",
} = Astro.props
---

<!doctype html>
<html lang="es" class="bg-background">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/image.png" />
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans antialiased">
    <slot />
  </body>
</html>
